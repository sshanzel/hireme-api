# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hiremenow

# JWT
JWT_SECRET=your-secret-key

ALLOWED_ORIGINS=http://localhost:3000

OPENAI_API_KEY=your-openai-api-key

# GCP
GCP_PROJECT_ID=your-project-id
GCS_BUCKET_NAME=your-bucket-name

# Pub/Sub (for local development with emulator)
PUBSUB_EMULATOR_HOST=localhost:8085

# For GCS signed URLs, run:
# gcloud auth application-default login --impersonate-service-account=your-sa@your-project.iam.gserviceaccount.com

# CV parser API
CV_PARSER_API_URL=https://api.edenai.run
CV_PARSER_API_KEY=your-edenai-api-key
